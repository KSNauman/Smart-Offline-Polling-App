<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Screen title -->
        <TextView
            android:id="@+id/tvVoteTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cast Your Vote"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Poll question — populated dynamically from parsed JSON -->
        <TextView
            android:id="@+id/tvPollQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="17sp"
            android:textColor="#1A1A1A"
            android:textStyle="bold"
            android:padding="14dp"
            android:background="#EEF2FF"
            android:layout_marginBottom="20dp" />

        <!-- "Select your choice" label -->
        <TextView
            android:id="@+id/tvOptionsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select your choice:"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <!--
            RadioGroup — all RadioButtons are added programmatically in VoteActivity.
            No placeholder children here; placeholder XML buttons have been removed.
        -->
        <RadioGroup
            android:id="@+id/rgVoteOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="28dp" />

        <!-- Submit button -->
        <Button
            android:id="@+id/btnSubmitVote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Submit Vote"
            android:textSize="16sp"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>

</ScrollView>
