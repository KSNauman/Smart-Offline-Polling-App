<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <!-- Title -->
        <TextView
            android:id="@+id/tvShowQrTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Poll QR Code"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- QR Code ImageView — Bitmap set programmatically from QRUtils -->
        <ImageView
            android:id="@+id/ivQrCode"
            android:layout_width="256dp"
            android:layout_height="256dp"
            android:background="#F0F0F0"
            android:contentDescription="QR Code"
            android:layout_marginBottom="16dp"
            android:scaleType="fitCenter" />

        <!-- Placeholder text — hidden once QR renders successfully -->
        <TextView
            android:id="@+id/tvQrPlaceholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QR will be shown here"
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:visibility="visible" />

        <!-- Debug: Raw poll JSON — shown below the QR for verification -->
        <TextView
            android:id="@+id/tvDebugLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Poll JSON (debug):"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#555555"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvPollJson"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#333333"
            android:fontFamily="monospace"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
